msgid "Citation Style"
msgstr "Styl cytowania"

msgid ""
"Changing styles reformats auto-generated citations and keeps manual "
"overrides intact."
msgstr ""
"Zmiana stylu powoduje ponowne sformatowanie cytowań generowanych "
"automatycznie, zachowując ręczne korekty."

msgid "Visible Heading"
msgstr "Widoczny nagłówek"

msgid ""
"Optional heading shown above the bibliography on the site front end when at "
"least one citation exists."
msgstr ""
"Opcjonalny nagłówek wyświetlany nad bibliografią w publicznej części "
"witryny, gdy istnieje co najmniej jedno cytowanie."

msgid "Output JSON-LD"
msgstr "Włącz JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "Pomaga wyszukiwarkom i innym narzędziom rozpoznawać bibliografię."

msgid "Output COinS"
msgstr "Włącz COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Pozwala Zotero i podobnym narzędziom wykrywać cytowania na stronie."

msgid "Output CSL-JSON"
msgstr "Włącz CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr ""
"Umożliwia ponowne wykorzystanie danych cytowań przez narzędzia i usługi "
"naukowe."

msgid "Exports"
msgstr "Eksport"

msgid "Copy bibliography"
msgstr "Kopiuj bibliografię"

msgid ""
"Copies the current bibliography as plain text in the current order and "
"style."
msgstr ""
"Kopiuje bieżącą bibliografię jako zwykły tekst w bieżącej kolejności i "
"stylu."

msgid "Download CSL-JSON"
msgstr "Pobierz CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Pobiera bieżącą bibliografię jako ustrukturyzowane dane cytowań."

msgid "Download BibTeX"
msgstr "Pobierz BibTeX"

msgid ""
"Downloads the current bibliography as BibTeX for reference-manager and "
"scholarly-writing workflows."
msgstr ""
"Pobiera bieżącą bibliografię jako BibTeX do menedżerów bibliografii i "
"akademickich procesów pisania."

msgid "Download RIS"
msgstr "Pobierz RIS"

msgid ""
"Downloads the current bibliography as RIS for citation managers and "
"import/export workflows."
msgstr ""
"Pobiera bieżącą bibliografię jako RIS dla menedżerów cytowań i procesów "
"importu/eksportu."

msgid "Notification"
msgstr "Powiadomienie"

msgid "Publication Type"
msgstr "Typ publikacji"

msgid "Select a publication type"
msgstr "Wybierz typ publikacji"

msgid "Save"
msgstr "Zapisz"

msgid "Cancel"
msgstr "Anuluj"

msgid "Post not found."
msgstr "Nie znaleziono wpisu."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "Nie masz uprawnień do odczytu tej bibliografii."

msgid "Bibliography block not found for the requested index."
msgstr "Nie znaleziono bloku bibliografii dla podanego indeksu."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID wpisu do sprawdzenia pod kątem bloków bibliografii."

msgid "Zero-based bibliography block index within the post."
msgstr "Indeks bloku bibliografii we wpisie (numeracja od zera)."

msgid "Response format: json, text, or csl-json."
msgstr "Format odpowiedzi: json, text lub csl-json."

