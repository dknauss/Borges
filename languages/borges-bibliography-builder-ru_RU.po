msgstr "URL"

msgid "Hide citation form"
msgstr "Скрыть форму цитирования"

msgid "Show citation form"
msgstr "Показать форму цитирования"

msgid "Settings"
msgstr "Настройки"

msgid "source"
msgstr "источник"

msgid "sources"
msgstr "источника"

msgid "Citation Style"
msgstr "Стиль цитирования"

msgid ""
"Changing styles reformats auto-generated citations and keeps manual "
"overrides intact."
msgstr ""
"Смена стиля переформатирует автоматически сгенерированные цитаты и сохраняет"
" ручные правки."

msgid "Visible Heading"
msgstr "Видимый заголовок"

msgid ""
"Optional heading shown above the bibliography on the site front end when at "
"least one citation exists."
msgstr ""
"Необязательный заголовок, отображаемый над библиографией на сайте при "
"наличии хотя бы одного источника."

msgid "Output JSON-LD"
msgstr "Включить JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr ""
"Помогает поисковым системам и другим инструментам распознавать библиографию."

msgid "Output COinS"
msgstr "Включить COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr ""
"Позволяет Zotero и аналогичным инструментам обнаруживать цитаты на странице."

msgid "Output CSL-JSON"
msgstr "Включить CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr ""
"Делает данные цитирования доступными для повторного использования в научных "
"инструментах и сервисах."

msgid "Exports"
msgstr "Экспорт"

msgid "Copy bibliography"
msgstr "Скопировать библиографию"

msgid ""
"Copies the current bibliography as plain text in the current order and "
"style."
msgstr ""
"Копирует текущую библиографию как обычный текст в текущем порядке и стиле."

msgid "Download CSL-JSON"
msgstr "Скачать CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr ""
"Скачивает текущую библиографию как структурированные данные цитирования."

msgid "Download BibTeX"
msgstr "Скачать BibTeX"

msgid ""
"Downloads the current bibliography as BibTeX for reference-manager and "
"scholarly-writing workflows."
msgstr ""
"Скачивает текущую библиографию как BibTeX для менеджеров ссылок и научно-"
"исследовательских рабочих процессов."

msgid "Download RIS"
msgstr "Скачать RIS"

msgid ""
"Downloads the current bibliography as RIS for citation managers and "
"import/export workflows."
msgstr ""
"Скачивает текущую библиографию как RIS для менеджеров цитирования и "
"процессов импорта/экспорта."

msgid "Notification"
msgstr "Уведомление"

msgid "Publication Type"
msgstr "Тип публикации"

msgid "Select a publication type"
msgstr "Выберите тип публикации"

msgid "Save"
msgstr "Сохранить"

msgid "Cancel"
msgstr "Отмена"

msgid "Post not found."
msgstr "Запись не найдена."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "У вас нет прав для просмотра этой библиографии."

msgid "Bibliography block not found for the requested index."
msgstr "Блок библиографии для указанного индекса не найден."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID записи для проверки на наличие блоков библиографии."

msgid "Zero-based bibliography block index within the post."
msgstr "Индекс блока библиографии внутри записи (нумерация с нуля)."

msgid "Response format: json, text, or csl-json."
msgstr "Формат ответа: json, text или csl-json."

