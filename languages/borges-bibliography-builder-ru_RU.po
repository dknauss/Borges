msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr ""
"Импортированные метаданные могут быть неполными. Проверьте их перед "
"публикацией."

msgid "Add citations"
msgstr "Добавить источники"

msgid "Paste / Import"
msgstr "Вставить / Импортировать"

msgid "Manual Entry"
msgstr "Ручной ввод"

msgid "Resolving…"
msgstr "Запрос…"

