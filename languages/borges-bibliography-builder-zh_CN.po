msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "导入的元数据可能不完整。请在发布前核对。"

msgid "Add citations"
msgstr "添加引文"

msgid "Paste / Import"
msgstr "粘贴 / 导入"

msgid "Manual Entry"
msgstr "手动录入"

msgid "Resolving…"
msgstr "解析中…"

msgid "Add"
msgstr "添加"

msgid "Clear"
msgstr "清除"

