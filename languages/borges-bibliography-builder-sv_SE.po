msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr ""
"Importerade metadata kan vara ofullständiga. Kontrollera innan publicering."

msgid "Add citations"
msgstr "Lägg till källhänvisningar"

msgid "Paste / Import"
msgstr "Klistra in / importera"

msgid "Manual Entry"
msgstr "Manuell inmatning"

msgid "Resolving…"
msgstr "Hämtar…"

msgid "Add"
msgstr "Lägg till"

msgid "Clear"
msgstr "Rensa"

