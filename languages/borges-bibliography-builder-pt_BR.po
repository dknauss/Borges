msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr ""
"Os metadados importados podem estar incompletos. Verifique-os antes de "
"publicar."

msgid "Add citations"
msgstr "Adicionar citações"

msgid "Paste / Import"
msgstr "Colar / Importar"

msgid "Manual Entry"
msgstr "Entrada manual"

msgid "Resolving…"
msgstr "Resolvendo…"

msgid "Add"
msgstr "Adicionar"

msgid "Clear"
msgstr "Limpar"

msgid "Author(s)"
msgstr "Autor(es)"

msgid "Title"
msgstr "Título"

msgid "Container"
msgstr "Publicação de origem"

msgid "Publisher"
msgstr "Editora"

msgid "Year"
msgstr "Ano"

msgid "Pages"
msgstr "Páginas"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "Ocultar formulário de citação"

msgid "Show citation form"
msgstr "Mostrar formulário de citação"

msgid "Settings"
msgstr "Configurações"

msgid "source"
msgstr "fonte"

msgid "sources"
msgstr "fontes"

msgid "Citation Style"
msgstr "Estilo de citação"

msgid ""
"Changing styles reformats auto-generated citations and keeps manual "
"overrides intact."
msgstr ""
"Alterar o estilo reformata as citações geradas automaticamente e mantém as "
"modificações manuais intactas."

msgid "Visible Heading"
msgstr "Cabeçalho visível"

msgid ""
"Optional heading shown above the bibliography on the site front end when at "
"least one citation exists."
msgstr ""
"Cabeçalho opcional exibido acima da bibliografia no site público quando "
"existir pelo menos uma citação."

msgid "Output JSON-LD"
msgstr "Gerar JSON-LD"

msgid "Helps search engines and other tools understand the bibliography."
msgstr ""
"Ajuda mecanismos de busca e outras ferramentas a entender a bibliografia."

msgid "Output COinS"
msgstr "Gerar COinS"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr ""
"Permite que o Zotero e ferramentas semelhantes detectem citações na página."

msgid "Output CSL-JSON"
msgstr "Gerar CSL-JSON"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr ""
"Torna os dados de citação reutilizáveis por ferramentas e serviços "
"acadêmicos."

msgid "Exports"
msgstr "Exportações"

msgid "Copy bibliography"
msgstr "Copiar bibliografia"

msgid ""
"Copies the current bibliography as plain text in the current order and "
"style."
msgstr ""
"Copia a bibliografia atual como texto simples, na ordem e no estilo atuais."

msgid "Download CSL-JSON"
msgstr "Baixar CSL-JSON"

msgid "Downloads the current bibliography as structured citation data."
msgstr "Baixa a bibliografia atual como dados de citação estruturados."

msgid "Download BibTeX"
msgstr "Baixar BibTeX"

msgid ""
"Downloads the current bibliography as BibTeX for reference-manager and "
"scholarly-writing workflows."
msgstr ""
"Baixa a bibliografia atual em BibTeX para gerenciadores de referências e "
"fluxos de escrita acadêmica."

msgid "Download RIS"
msgstr "Baixar RIS"

msgid ""
"Downloads the current bibliography as RIS for citation managers and "
"import/export workflows."
msgstr ""
"Baixa a bibliografia atual em RIS para gerenciadores de citação e fluxos de "
"importação/exportação."

msgid "Notification"
msgstr "Notificação"

msgid "Publication Type"
msgstr "Tipo de publicação"

msgid "Select a publication type"
msgstr "Selecione um tipo de publicação"

msgid "Save"
msgstr "Salvar"

msgid "Cancel"
msgstr "Cancelar"

msgid "Post not found."
msgstr "Publicação não encontrada."

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "Você não tem permissão para ler esta bibliografia."

msgid "Bibliography block not found for the requested index."
msgstr "Bloco de bibliografia não encontrado para o índice solicitado."

msgid "Post ID to inspect for bibliography blocks."
msgstr "ID da publicação a ser inspecionada para blocos de bibliografia."

msgid "Zero-based bibliography block index within the post."
msgstr "Índice do bloco de bibliografia dentro da publicação, com base zero."

msgid "Response format: json, text, or csl-json."
msgstr "Formato da resposta: json, text ou csl-json."

