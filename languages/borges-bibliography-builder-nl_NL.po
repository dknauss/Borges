msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr ""
"Geïmporteerde metadata kunnen onvolledig zijn. Controleer dit vóór "
"publicatie."

msgid "Add citations"
msgstr "Citaten toevoegen"

msgid "Paste / Import"
msgstr "Plakken / Importeren"

msgid "Manual Entry"
msgstr "Handmatige invoer"

msgid "Resolving…"
msgstr "Ophalen…"

