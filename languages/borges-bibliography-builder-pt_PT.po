msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr ""
"Os metadados importados podem estar incompletos. Verifique-os antes de "
"publicar."

msgid "Add citations"
msgstr "Adicionar citações"

msgid "Paste / Import"
msgstr "Colar / Importar"

msgid "Manual Entry"
msgstr "Introdução manual"

msgid "Resolving…"
msgstr "A resolver…"

msgid "Add"
msgstr "Adicionar"

msgid "Clear"
msgstr "Limpar"

