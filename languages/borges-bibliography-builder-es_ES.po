msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr ""
"Los metadatos importados pueden estar incompletos. Verifícalos antes de "
"publicar."

msgid "Add citations"
msgstr "Añadir citas"

msgid "Paste / Import"
msgstr "Pegar / Importar"

msgid "Manual Entry"
msgstr "Entrada manual"

msgid "Resolving…"
msgstr "Resolviendo…"

