msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr ""
"Les métadonnées importées peuvent être incomplètes. Vérifiez-les avant "
"publication."

msgid "Add citations"
msgstr "Ajouter des citations"

msgid "Paste / Import"
msgstr "Coller / Importer"

msgid "Manual Entry"
msgstr "Saisie manuelle"

msgid "Resolving…"
msgstr "Résolution en cours…"

