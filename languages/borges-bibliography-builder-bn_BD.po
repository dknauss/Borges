msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "আমদানি করা মেটাডেটা অসম্পূর্ণ হতে পারে। প্রকাশের আগে যাচাই করুন।"

msgid "Add citations"
msgstr "উদ্ধৃতি যোগ করুন"

msgid "Paste / Import"
msgstr "পেস্ট / আমদানি"

msgid "Manual Entry"
msgstr "হস্তচালিত প্রবিষ্টি"

msgid "Resolving…"
msgstr "DOI নিষ্পত্তি হচ্ছে…"

msgid "Add"
msgstr "যোগ করুন"

msgid "Clear"
msgstr "মুছুন"

msgid "Author(s)"
msgstr "লেখক"

msgid "Title"
msgstr "শিরোনাম"

msgid "Container"
msgstr "প্রকাশ মাধ্যম"

msgid "Publisher"
msgstr "প্রকাশক"

msgid "Year"
msgstr "বছর"

msgid "Pages"
msgstr "পৃষ্ঠা"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "উদ্ধৃতি ফর্ম লুকান"

msgid "Show citation form"
msgstr "উদ্ধৃতি ফর্ম দেখান"

msgid "Settings"
msgstr "সেটিংস"

msgid "source"
msgstr "উৎস"

msgid "sources"
msgstr "উৎস"

msgid "Citation Style"
msgstr "উদ্ধৃতি শৈলী"

msgid ""
"Changing styles reformats auto-generated citations and keeps manual "
"overrides intact."
msgstr ""
"শৈলী পরিবর্তন করলে স্বয়ংক্রিয়ভাবে তৈরি উদ্ধৃতিগুলি পুনরায় বিন্যাসিত হয়; "
"হস্তচালিত পরিবর্তন অপরিবর্তিত থাকে।"

msgid "Visible Heading"
msgstr "দৃশ্যমান শিরোনাম"

msgid ""
"Optional heading shown above the bibliography on the site front end when at "
"least one citation exists."
msgstr ""
"অন্তত একটি উদ্ধৃতি থাকলে সাইটের সামনের অংশে গ্রন্থপঞ্জির উপরে প্রদর্শিত "
"ঐচ্ছিক শিরোনাম।"

msgid "Output JSON-LD"
msgstr "JSON-LD আউটপুট"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "সার্চ ইঞ্জিন ও অন্যান্য সরঞ্জামকে গ্রন্থপঞ্জি বুঝতে সাহায্য করে।"

msgid "Output COinS"
msgstr "COinS আউটপুট"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Zotero ও অনুরূপ সরঞ্জামকে পাতায় উদ্ধৃতি শনাক্ত করতে দেয়।"

msgid "Output CSL-JSON"
msgstr "CSL-JSON আউটপুট"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr ""
"উদ্ধৃতি ডেটাকে শিক্ষায়তনিক সরঞ্জাম ও সেবার জন্য পুনর্ব্যবহারযোগ্য করে তোলে।"

msgid "Exports"
msgstr "রপ্তানি"

msgid "Copy bibliography"
msgstr "গ্রন্থপঞ্জি অনুলিপি করুন"

msgid ""
"Copies the current bibliography as plain text in the current order and "
"style."
msgstr ""
"বর্তমান ক্রম ও শৈলীতে বর্তমান গ্রন্থপঞ্জিকে সরল পাঠ্যরূপে অনুলিপি করে।"

msgid "Download CSL-JSON"
msgstr "CSL-JSON ডাউনলোড করুন"

msgid "Downloads the current bibliography as structured citation data."
msgstr "বর্তমান গ্রন্থপঞ্জিকে কাঠামোবদ্ধ উদ্ধৃতি ডেটা হিসেবে ডাউনলোড করে।"

msgid "Download BibTeX"
msgstr "BibTeX ডাউনলোড করুন"

msgid ""
"Downloads the current bibliography as BibTeX for reference-manager and "
"scholarly-writing workflows."
msgstr ""
"তথ্যসূত্র ব্যবস্থাপক ও গবেষণামূলক লেখার কর্মপ্রবাহের জন্য বর্তমান "
"গ্রন্থপঞ্জিকে BibTeX হিসেবে ডাউনলোড করে।"

msgid "Download RIS"
msgstr "RIS ডাউনলোড করুন"

msgid ""
"Downloads the current bibliography as RIS for citation managers and "
"import/export workflows."
msgstr ""
"উদ্ধৃতি ব্যবস্থাপক ও আমদানি/রপ্তানি কর্মপ্রবাহের জন্য বর্তমান গ্রন্থপঞ্জিকে "
"RIS হিসেবে ডাউনলোড করে।"

msgid "Notification"
msgstr "বিজ্ঞপ্তি"

msgid "Publication Type"
msgstr "প্রকাশনার ধরন"

msgid "Select a publication type"
msgstr "একটি প্রকাশনার ধরন নির্বাচন করুন"

msgid "Save"
msgstr "সংরক্ষণ করুন"

msgid "Cancel"
msgstr "বাতিল করুন"

msgid "Post not found."
msgstr "পোস্ট পাওয়া যায়নি।"

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "দুঃখিত, এই গ্রন্থপঞ্জি পড়ার অনুমতি আপনার নেই।"

msgid "Bibliography block not found for the requested index."
msgstr "চাওয়া সূচকের জন্য গ্রন্থপঞ্জি ব্লক পাওয়া যায়নি।"

msgid "Post ID to inspect for bibliography blocks."
msgstr "গ্রন্থপঞ্জি ব্লক পরীক্ষার জন্য পোস্ট ID।"

msgid "Zero-based bibliography block index within the post."
msgstr "পোস্টের মধ্যে শূন্য-ভিত্তিক গ্রন্থপঞ্জি ব্লক সূচক।"

msgid "Response format: json, text, or csl-json."
msgstr "প্রতিক্রিয়া বিন্যাস: json, text, বা csl-json।"

