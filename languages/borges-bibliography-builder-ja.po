msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "インポートしたメタデータは不完全な場合があります。公開前にご確認ください。"

msgid "Add citations"
msgstr "引用を追加"

msgid "Paste / Import"
msgstr "貼り付け / インポート"

msgid "Manual Entry"
msgstr "手動入力"

msgid "Resolving…"
msgstr "解決中…"

msgid "Add"
msgstr "追加"

msgid "Clear"
msgstr "クリア"

msgid "Author(s)"
msgstr "著者"

msgid "Title"
msgstr "タイトル"

msgid "Container"
msgstr "掲載先"

msgid "Publisher"
msgstr "出版社"

msgid "Year"
msgstr "年"

msgid "Pages"
msgstr "ページ"

msgid "DOI"
msgstr "DOI"

msgid "URL"
msgstr "URL"

msgid "Hide citation form"
msgstr "引用フォームを非表示"

msgid "Show citation form"
msgstr "引用フォームを表示"

msgid "Settings"
msgstr "設定"

msgid "source"
msgstr "件"

msgid "sources"
msgstr "件"

msgid "Citation Style"
msgstr "引用スタイル"

msgid ""
"Changing styles reformats auto-generated citations and keeps manual "
"overrides intact."
msgstr "スタイルを変更すると自動生成された引用は再整形され、手動で変更した内容は保持されます。"

msgid "Visible Heading"
msgstr "表示見出し"

msgid ""
"Optional heading shown above the bibliography on the site front end when at "
"least one citation exists."
msgstr "引用が 1 件以上ある場合に、サイトのフロントエンドで参考文献リストの上に表示される任意の見出しです。"

msgid "Output JSON-LD"
msgstr "JSON-LD を出力"

msgid "Helps search engines and other tools understand the bibliography."
msgstr "検索エンジンや他のツールが参考文献を解釈するのに役立ちます。"

msgid "Output COinS"
msgstr "COinS を出力"

msgid "Lets Zotero and similar tools detect citations on the page."
msgstr "Zotero などのツールがページ上の引用を検出できるようにします。"

msgid "Output CSL-JSON"
msgstr "CSL-JSON を出力"

msgid "Makes citation data reusable by scholarly tools and services."
msgstr "学術ツールやサービスで引用データを再利用できるようにします。"

msgid "Exports"
msgstr "エクスポート"

msgid "Copy bibliography"
msgstr "参考文献をコピー"

msgid ""
"Copies the current bibliography as plain text in the current order and "
"style."
msgstr "現在の順序とスタイルで参考文献をプレーンテキストとしてコピーします。"

msgid "Download CSL-JSON"
msgstr "CSL-JSON をダウンロード"

msgid "Downloads the current bibliography as structured citation data."
msgstr "現在の参考文献を構造化された引用データとしてダウンロードします。"

msgid "Download BibTeX"
msgstr "BibTeX をダウンロード"

msgid ""
"Downloads the current bibliography as BibTeX for reference-manager and "
"scholarly-writing workflows."
msgstr "現在の参考文献を、文献管理・学術執筆ワークフロー向けの BibTeX としてダウンロードします。"

msgid "Download RIS"
msgstr "RIS をダウンロード"

msgid ""
"Downloads the current bibliography as RIS for citation managers and "
"import/export workflows."
msgstr "現在の参考文献を、文献管理ツールやインポート・エクスポート向けの RIS としてダウンロードします。"

msgid "Notification"
msgstr "通知"

msgid "Publication Type"
msgstr "資料種別"

msgid "Select a publication type"
msgstr "資料種別を選択"

msgid "Save"
msgstr "保存"

msgid "Cancel"
msgstr "キャンセル"

msgid "Post not found."
msgstr "投稿が見つかりません。"

msgid "Sorry, you are not allowed to read this bibliography."
msgstr "この参考文献を閲覧する権限がありません。"

msgid "Bibliography block not found for the requested index."
msgstr "指定されたインデックスの参考文献ブロックが見つかりません。"

msgid "Post ID to inspect for bibliography blocks."
msgstr "参考文献ブロックを検索する投稿 ID。"

msgid "Zero-based bibliography block index within the post."
msgstr "投稿内の参考文献ブロックの 0 始まりのインデックス。"

msgid "Response format: json, text, or csl-json."
msgstr "応答形式: json、text、または csl-json。"

