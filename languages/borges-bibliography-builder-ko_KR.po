msgid "Imported metadata may be incomplete. Verify before publishing."
msgstr "가져온 메타데이터가 불완전할 수 있습니다. 게시 전에 확인하세요."

msgid "Add citations"
msgstr "인용 추가"

msgid "Paste / Import"
msgstr "붙여넣기 / 가져오기"

msgid "Manual Entry"
msgstr "직접 입력"

msgid "Resolving…"
msgstr "확인 중…"

